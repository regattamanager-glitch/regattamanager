import { NextRequest, NextResponse } from "next/server";
import sql from '@/lib/db';

export const dynamic = "force-dynamic";
export const fetchCache = "force-no-store";

export async function GET(req: NextRequest) {
  try {
    // 1. Zählungen aus deiner Neon-Datenbank holen (Groß-/Kleinschreibung korrigiert!)
    const resEvents = await sql`SELECT COUNT(*)::int AS anz FROM events`;
    const resSegler = await sql`SELECT COUNT(*)::int AS anz FROM "Segler"`;
    const resVereine = await sql`SELECT COUNT(*)::int AS anz FROM "Verein"`;

    const eventsCount = resEvents[0]?.anz ?? 0;
    const seglerCount = resSegler[0]?.anz ?? 0;
    const vereineCount = resVereine[0]?.anz ?? 0;

    // 2. Vereine abrufen (passend zu deinen Tabellenspalten)
    const vereineList = await sql`
      SELECT id, name, kuerzel, email, adresse, "isApproved", "stripeAccountId", "createdAt"
      FROM "Verein" 
      ORDER BY "createdAt" DESC
    `;

    // 3. Events abrufen (Spalten laut deinem ersten Screenshot: datum_von, datum_bis)
    const eventsList = await sql`
      SELECT id, name, datum_von AS "datumVon", datum_bis AS "datumBis"
      FROM events 
      ORDER BY datum_von DESC
    `;

    // Dummy-Umsätze hinzufügen, damit die Diagramme rendern
    const eventsWithRevenue = eventsList.map((event, index) => ({
      id: event.id,
      name: event.name,
      datumVon: event.datumVon,
      datumBis: event.datumBis,
      revenue: index % 2 === 0 ? 1250.00 : 750.00
    }));

    // 4. Registrierungs-Timeline für die Segler-Kurve holen
    const timelineData = await sql`
      SELECT 
        TO_CHAR("createdAt", 'YYYY-MM') AS month,
        COUNT(*)::int AS zuwachs
      FROM "Segler"
      GROUP BY month
      ORDER BY month ASC
      LIMIT 6
    `;

    const finalTimeline = timelineData.length > 0 ? timelineData : [
      { month: "2026-04", zuwachs: 5 },
      { month: "2026-05", zuwachs: seglerCount }
    ];

    return NextResponse.json({
      success: true,
      stats: {
        eventsCount,
        seglerCount,
        vereineCount
      },
      vereine: vereineList,
      events: eventsWithRevenue,
      timeline: finalTimeline
    });

  } catch (err: any) {
    console.error("Admin-API Fehler:", err);
    return NextResponse.json(
      { success: false, message: "Datenbankfehler", error: err.message }, 
      { status: 500 }
    );
  }
}

export async function POST(req: NextRequest) {
  try {
    const body = await req.json().catch(() => ({}));
    const { vereinId, isApproved } = body;

    if (!vereinId) {
      return NextResponse.json({ success: false, message: "Keine Vereins-ID übergeben" }, { status: 400 });
    }

    await sql`
      UPDATE "Verein"
      SET "isApproved" = ${isApproved}, "updatedAt" = NOW()
      WHERE id = ${vereinId}
    `;

    return NextResponse.json({ success: true, message: "Status geändert" });
  } catch (err: any) {
    return NextResponse.json({ success: false, error: err.message }, { status: 500 });
  }
}
